[sub_resource type="Shader" id="Shader_leftdecor_fade"]
code = "shader_type canvas_item;

// 从左到右：左侧保持原不透明，右侧渐隐至完全透明
uniform float fade_start = 0.0;
uniform float fade_end = 1.0;

void fragment() {
	vec4 c = texture(TEXTURE, UV);
	float t = smoothstep(fade_start, fade_end, UV.x);
	c.a *= 1.0 - t;
	COLOR = c;
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_leftdecor_fade"]
shader = SubResource("Shader_leftdecor_fade")
shader_parameter/fade_start = 0.0
shader_parameter/fade_end = 0.55

